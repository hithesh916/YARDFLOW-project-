# Copy to .env and fill in real values. Do NOT commit .env.
#
# YARDFLOW database connection (MySQL / MariaDB).
#
# Deployment: the app runs on Vercel and connects to your cPanel MySQL over the
# internet (cPanel > Remote MySQL must allow the host). Use the cPanel SERVER's
# IP/hostname (cPanel home > "Shared IP Address"), NOT your website domain — the
# domain points to Vercel. cPanel prefixes DB and user names with your account,
# e.g. acct_yardflow and acct_yfuser. connection_limit keeps Prisma from
# exhausting shared hosting's low per-user connection cap.
#
#   mysql://acct_yfuser:THE_PASSWORD@CPANEL_SERVER_IP:3306/acct_yardflow?connection_limit=3
#
# Local dev against a local MySQL, if you ever want one:
#   mysql://root:yourpassword@localhost:3306/yardflow
DATABASE_URL="mysql://USER:PASSWORD@CPANEL_SERVER_IP:3306/DBNAME?connection_limit=3"
